{
  "openapi": "3.0.3",
  "info": {
    "title": "Test API",
    "version": "1.0.0"
  },
  "paths": {
    "/auth/google": {
      "post": {
        "summary": "Authenticate with Google",
        "tags": [
          "Users"
        ],
        "description": "Verify a Google ID token and issue JWT tokens. Handles returning users, invited users, and new user creation.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "idToken": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "idToken"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string"
                        },
                        "refreshToken": {
                          "type": "string"
                        },
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "format": "uuid",
                              "type": "string"
                            },
                            "email": {
                              "format": "email",
                              "type": "string"
                            },
                            "name": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "null"
                                }
                              ]
                            },
                            "avatar_url": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "null"
                                }
                              ]
                            },
                            "auth_provider": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "email",
                            "name",
                            "avatar_url",
                            "auth_provider"
                          ]
                        },
                        "organization": {
                          "anyOf": [
                            {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "format": "uuid",
                                  "type": "string"
                                },
                                "name": {
                                  "type": "string"
                                }
                              },
                              "required": [
                                "id",
                                "name"
                              ]
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "needs_onboarding": {
                          "type": "boolean"
                        },
                        "invite_accepted": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "accessToken",
                        "refreshToken",
                        "user",
                        "organization",
                        "needs_onboarding",
                        "invite_accepted"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "allOf": [
                        {
                          "type": "string"
                        },
                        {
                          "default": "Unauthorized",
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "allOf": [
                        {
                          "type": "string"
                        },
                        {
                          "default": "Too Many Requests",
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "allOf": [
                        {
                          "type": "string"
                        },
                        {
                          "default": "Internal Server Error",
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "allOf": [
                        {
                          "type": "string"
                        },
                        {
                          "default": "Service Unavailable",
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}