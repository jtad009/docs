{
  "openapi": "3.0.3",
  "info": {
    "title": "Feature Flag API",
    "version": "1.0.0",
    "description": "API documentation for the Feature Flag service"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Login a user",
        "tags": [
          "Users"
        ],
        "description": "Generate AUTH Token for authorized users. This endpoint is rate-limited to 5 requests per minute.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "format": "email",
                    "type": "string"
                  },
                  "password": {
                    "minLength": 6,
                    "type": "string"
                  },
                  "rememberMe": {
                    "default": false,
                    "type": "boolean"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          },
          "required": true
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "header",
            "name": "x-timezone",
            "required": false,
            "description": "User timezone (e.g., America/New_York, UTC+1). Defaults to UTC."
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string"
                        },
                        "refreshToken": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "accessToken",
                        "refreshToken"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Unauthorized"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/auth/google": {
      "post": {
        "summary": "Authenticate with Google",
        "tags": [
          "Users"
        ],
        "description": "Verify a Google ID token and issue JWT tokens. Handles returning users, invited users, and new user creation.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "idToken": {
                    "minLength": 1,
                    "type": "string"
                  }
                },
                "required": [
                  "idToken"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string"
                        },
                        "refreshToken": {
                          "type": "string"
                        },
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "format": "uuid",
                              "type": "string"
                            },
                            "email": {
                              "format": "email",
                              "type": "string"
                            },
                            "name": {
                              "type": "string",
                              "nullable": true
                            },
                            "avatar_url": {
                              "type": "string",
                              "nullable": true
                            },
                            "auth_provider": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "email",
                            "name",
                            "avatar_url",
                            "auth_provider"
                          ]
                        },
                        "organization": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "format": "uuid",
                              "type": "string"
                            },
                            "name": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "id",
                            "name"
                          ],
                          "nullable": true
                        },
                        "needs_onboarding": {
                          "type": "boolean"
                        },
                        "invite_accepted": {
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "accessToken",
                        "refreshToken",
                        "user",
                        "organization",
                        "needs_onboarding",
                        "invite_accepted"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Unauthorized"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Too Many Requests"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Internal Server Error"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "503": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Service Unavailable"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh-token": {
      "post": {
        "summary": "Refresh an auth token",
        "tags": [
          "Users"
        ],
        "description": "Generates a new access token and refresh token using a valid refresh token.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refreshToken": {
                    "type": "string"
                  }
                },
                "required": [
                  "refreshToken"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "accessToken": {
                          "type": "string"
                        },
                        "refreshToken": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "accessToken",
                        "refreshToken"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Unauthorized"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "put": {
        "summary": "Update user profile (authenticated)",
        "tags": [
          "Users"
        ],
        "description": "Allow authenticated users to update their profile information including name, job title, and avatar. Password changes require current password verification. This endpoint is rate-limited to 10 requests per 15 minutes.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "timezone": {
                    "description": "User timezone (e.g., America/New_York, UTC+1).",
                    "pattern": "^(?:[A-Za-z_]+(?:\\/[A-Za-z0-9_\\-]+)+|(?:UTC|GMT)(?:[+-](?:0?[0-9]|1[0-4])(?::?[0-5][0-9])?)?|[+-](?:0?[0-9]|1[0-4]):?[0-5][0-9])$",
                    "type": "string"
                  },
                  "name": {
                    "minLength": 1,
                    "maxLength": 100,
                    "type": "string"
                  },
                  "job_title": {
                    "maxLength": 200,
                    "type": "string",
                    "nullable": true
                  },
                  "currentPassword": {
                    "minLength": 6,
                    "description": "Required if changing password",
                    "type": "string"
                  },
                  "newPassword": {
                    "minLength": 8,
                    "maxLength": 128,
                    "description": "Required if changing password",
                    "type": "string"
                  },
                  "confirmPassword": {
                    "minLength": 8,
                    "maxLength": 128,
                    "description": "Must match newPassword",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "format": "uuid",
                          "type": "string"
                        },
                        "email": {
                          "format": "email",
                          "type": "string"
                        },
                        "name": {
                          "type": "string",
                          "nullable": true
                        },
                        "job_title": {
                          "type": "string",
                          "nullable": true
                        },
                        "avatar_url": {
                          "type": "string",
                          "nullable": true
                        },
                        "timezone": {
                          "type": "string",
                          "nullable": true
                        },
                        "status": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "active"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "invited"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "disabled"
                              ]
                            }
                          ]
                        },
                        "role": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "admin"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "editor"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "viewer"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "support"
                              ]
                            }
                          ]
                        },
                        "org_id": {
                          "format": "uuid",
                          "type": "string"
                        },
                        "created_at": {
                          "format": "date-time",
                          "type": "string"
                        },
                        "last_login": {
                          "format": "date-time",
                          "type": "string",
                          "nullable": true
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id",
                        "email",
                        "name",
                        "job_title",
                        "avatar_url",
                        "timezone",
                        "status",
                        "role",
                        "org_id",
                        "created_at",
                        "last_login",
                        "message"
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Bad Request"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Unauthorized"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Resource not found"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Internal Server Error"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get user profile",
        "tags": [
          "Users"
        ],
        "description": "Retrieves the authenticated user's profile information.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "format": "uuid",
                          "type": "string"
                        },
                        "email": {
                          "format": "email",
                          "type": "string"
                        },
                        "name": {
                          "type": "string",
                          "nullable": true
                        },
                        "avatar_url": {
                          "type": "string",
                          "nullable": true
                        },
                        "status": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "active"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "invited"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "disabled"
                              ]
                            }
                          ]
                        },
                        "created_at": {
                          "format": "date-time",
                          "type": "string"
                        },
                        "last_login": {
                          "format": "date-time",
                          "type": "string",
                          "nullable": true
                        },
                        "role": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "admin"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "editor"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "viewer"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "support"
                              ]
                            }
                          ]
                        },
                        "org_id": {
                          "format": "uuid",
                          "type": "string"
                        },
                        "job_title": {
                          "type": "string",
                          "nullable": true
                        },
                        "timezone": {
                          "type": "string"
                        },
                        "organization": {
                          "type": "object",
                          "additionalProperties": true
                        },
                        "needs_onboarding": {
                          "type": "boolean"
                        },
                        "auth_provider": {
                          "description": "Authentication provider (e.g., local, google)",
                          "type": "string"
                        }
                      },
                      "required": [
                        "id",
                        "email",
                        "name",
                        "avatar_url",
                        "status"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Unauthorized"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      }
    },
