    "/plan-limits/plans": {
      "get": {
        "tags": [
          "Plans"
        ],
        "description": "List all available plans in the system. Accessible only to support admins.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "format": "uuid",
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "max_projects": {
                            "type": "number",
                            "nullable": true,
                            "description": "Max projects allowed. Null means unlimited."
                          },
                          "max_flags": {
                            "type": "number",
                            "nullable": true,
                            "description": "Max flags allowed. Null means unlimited."
                          },
                          "max_environments": {
                            "type": "number",
                            "nullable": true,
                            "description": "Max environments allowed. Null means unlimited."
                          },
                          "max_api_calls": {
                            "type": "number",
                            "nullable": true,
                            "description": "Monthly API call limit. Null means unlimited."
                          },
                          "trial_days": {
                            "type": "number",
                            "nullable": true
                          },
                          "deleted_at": {
                            "format": "date-time",
                            "type": "string",
                            "nullable": true
                          },
                          "stripe_product_id": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe product ID associated with this plan."
                          },
                          "stripe_price_id": {
                            "type": "string",
                            "nullable": true,
                            "description": "Legacy single Stripe price ID."
                          },
                          "stripe_monthly_price_id": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe price ID for monthly billing."
                          },
                          "stripe_annual_price_id": {
                            "type": "string",
                            "nullable": true,
                            "description": "Stripe price ID for annual billing."
                          },
                          "most_popular": {
                            "default": false,
                            "description": "Used to highlight a plan in marketing.",
                            "type": "boolean"
                          },
                          "product_link": {
                            "format": "uri",
                            "type": "string",
                            "nullable": true,
                            "description": "Optional checkout link for this plan."
                          },
                          "overage_rate_eur_cents": {
                            "type": "integer",
                            "nullable": true,
                            "description": "Price per 1M overage block in euro cents. Null = no overage."
                          },
                          "overage_block_size": {
                            "type": "integer",
                            "nullable": true,
                            "description": "API calls per overage block (default 1,000,000)."
                          },
                          "grace_buffer_pct": {
                            "type": "integer",
                            "nullable": true,
                            "description": "Percentage above included calls before overage kicks in (default 20)."
                          }
                        },
                        "required": [
                          "id",
                          "name",
                          "max_projects",
                          "max_flags",
                          "max_environments",
