    "/projects/{projectId}/environments/{envId}/flags/{flagId}/value": {
      "get": {
        "summary": "Get flag value",
        "tags": [
          "Flag Values"
        ],
        "description": "\nFetch the full configuration of a flag in a specific project + environment.  \n**Access:** Viewers, Editors, Admins, or SDKs with read-only token for the project.  \nReturns the flag’s value, type, targeting rules, and rollout strategy.",
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "projectId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "envId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "flagId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "key": {
                          "minLength": 1,
                          "type": "string"
                        },
                        "value": {},
                        "type": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "boolean"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "string"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "number"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "json"
                              ]
                            }
                          ]
                        },
                        "off_variation_id": {
                          "format": "uuid",
                          "type": "string"
                        },
                        "targeting_rules": {
                          "deprecated": true,
                          "description": "DEPRECATED: Use /flags/:flagId/targeting-rules API instead. This field is maintained for backward compatibility only.",
                          "type": "array",
                          "items": {
                            "anyOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "rule"
                                    ]
                                  },
                                  "attribute": {
                                    "type": "string"
                                  },
                                  "operator": {
                                    "anyOf": [
                                      {
                                        "type": "string",
                                        "enum": [
                                          "eq"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "neq"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "in"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "nin"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "exists"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "not_exists"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "gt"
                                        ]
                                      },
                                      {
                                        "type": "string",
                                        "enum": [
                                          "lt"
                                        ]
                                      }
                                    ]
                                  },
                                  "value": {
                                    "anyOf": [
                                      {
                                        "type": "string"
                                      },
                                      {
                                        "type": "array",
                                        "items": {
                                          "type": "string"
                                        }
                                      }
                                    ]
                                  }
                                },
                                "required": [
                                  "type",
                                  "attribute",
                                  "operator"
                                ]
                              },
                              {
                                "additionalProperties": false,
                                "type": "object",
                                "properties": {
                                  "type": {
                                    "type": "string",
                                    "enum": [
                                      "segment"
                                    ]
                                  },
                                  "segment_id": {
                                    "format": "uuid",
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "type",
                                  "segment_id"
                                ]
                              }
                            ]
                          }
                        },
                        "rollout": {
                          "anyOf": [
                            {
                              "title": "Gradual Rollout",
                              "description": "Boolean-only time-based progressive rollout. Automatically increases percentage over time at scheduled intervals.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "type": "string",
                                  "enum": [
                                    "gradual"
                                  ]
                                },
                                "target_percentage": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Final target percentage (0-100)",
                                  "type": "number"
                                },
                                "increment": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Percentage to increase per interval (0-100)",
                                  "type": "number"
                                },
                                "interval_hours": {
                                  "minimum": 0,
                                  "description": "Hours between each increment",
                                  "type": "number"
                                },
                                "salt": {
                                  "description": "Salt for hash bucketing to ensure consistent user experience",
                                  "type": "string"
                                },
                                "start_at": {
                                  "format": "date-time",
                                  "description": "ISO 8601 timestamp when rollout starts (defaults to immediate)",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "strategy",
                                "target_percentage",
                                "increment",
                                "interval_hours",
                                "salt"
                              ]
                            },
                            {
                              "title": "Off Rollout",
                              "description": "Always returns the fallback value. Use when feature is disabled or not ready.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "type": "string",
                                  "enum": [
                                    "off"
                                  ]
                                }
                              },
                              "required": [
                                "strategy"
                              ]
                            },
                            {
                              "title": "Percentage Rollout",
                              "description": "Boolean-only progressive rollout. Enables feature for a fixed percentage of users.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "type": "string",
                                  "enum": [
                                    "percentage"
                                  ]
                                },
                                "percentage": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Percentage of users to enable (0-100)",
                                  "type": "number"
                                },
                                "salt": {
                                  "description": "Salt for hash bucketing to ensure consistent user experience",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "strategy",
                                "percentage",
                                "salt"
                              ]
                            },
                            {
                              "title": "Variant Rollout",
                              "description": "Multivariate A/B testing. Distributes users across multiple variants based on weights.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "type": "string",
                                  "enum": [
                                    "variant"
                                  ]
                                },
                                "salt": {
                                  "description": "Salt for hash bucketing to ensure consistent user experience",
                                  "type": "string"
                                },
                                "variants": {
                                  "description": "List of variants with their weights. Weights must sum to exactly 100 (validator must check sum == 100).",
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "variation_id": {
                                        "type": "string"
                                      },
                                      "weight": {
                                        "minimum": 0,
                                        "maximum": 100,
                                        "description": "Weight for this variant (must sum to 100)",
                                        "type": "number"
                                      }
                                    },
                                    "required": [
                                      "variation_id",
                                      "weight"
                                    ]
                                  }
                                }
                              },
                              "required": [
                                "strategy",
                                "salt",
                                "variants"
                              ]
                            },
                            {
                              "type": "string",
                              "nullable": true
                            }
                          ]
                        }
                      },
                      "required": [
                        "value",
                        "type",
                        "targeting_rules"
                      ]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Resource not found"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete flag value",
        "tags": [
          "Flag Values"
        ],
        "description": "\nNote: This resource is soft-deleted using a **deleted_at** timestamp. \nDeleted data will be **permanently removed** after 90 days. \nYou can still retrieve and export it within that window using an admin interface or API.\n",
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "projectId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "envId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "flagId",
            "required": true
          }
        ],
        "responses": {
          "204": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {}
                }
              }
            }
          }
        }
      }
    },
    "/projects/{projectId}/flags/{flagId}/environments/{envId}/rollouts": {
      "post": {
        "summary": "Create rollout",
        "tags": [
          "Rollouts"
        ],
        "description": "\nCreate a new rollout configuration for a flag in a specific environment.\n\n**Strategies:**\n- `off`: Always returns the fallback value\n- `percentage`: Boolean-only progressive rollout\n- `variant`: Multivariate A/B testing with flag variations\n- `gradual`: Time-based progressive rollout\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "title": "Rollout Configuration",
                "description": "Choose one strategy: \"off\" (disabled), \"percentage\" (progressive boolean), \"variant\" (A/B testing), or \"gradual\" (time-based progressive).",
                "anyOf": [
                  {
                    "title": "Off Config",
                    "description": "Always returns the fallback value. No variations are used.",
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "description": "Disables the rollout",
                        "type": "string",
                        "enum": [
                          "off"
                        ]
                      }
                    },
                    "required": [
                      "strategy"
                    ]
                  },
                  {
                    "title": "Percentage Config",
                    "description": "Progressive rollout - boolean flags that gradually enable for a percentage of users.",
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "description": "Progressive rollout - users are bucketed by percentage",
                        "type": "string",
                        "enum": [
                          "percentage"
                        ]
                      },
                      "variation_id": {
                        "format": "uuid",
                        "description": "Valid UUID v4 format",
                        "type": "string"
                      },
                      "percentage": {
                        "minimum": 0,
                        "maximum": 100,
                        "description": "Percentage of users to enable this variation for (0-100)",
                        "type": "number"
                      },
                      "salt": {
                        "description": "Salt for consistent hash bucketing across users. Auto-generated if omitted.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "strategy",
                      "variation_id",
                      "percentage"
                    ]
                  },
                  {
                    "title": "Variant Config",
                    "description": "Multivariate A/B testing - distribute users across multiple variations with weighted traffic allocation.",
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "description": "Multivariate testing - distribute users across multiple variations",
                        "type": "string",
                        "enum": [
                          "variant"
                        ]
                      },
                      "variants": {
                        "minItems": 1,
                        "description": "List of variations with weights. Weights must sum to exactly 100%.",
                        "type": "array",
                        "items": {
                          "description": "A variant with its traffic allocation weight",
                          "type": "object",
                          "properties": {
                            "variation_id": {
                              "format": "uuid",
                              "description": "Valid UUID v4 format",
                              "type": "string"
                            },
                            "weight": {
                              "minimum": 0,
                              "maximum": 100,
                              "description": "Relative weight for this variant. All weights must sum to 100.",
                              "type": "number"
                            }
                          },
                          "required": [
                            "variation_id",
                            "weight"
                          ]
                        }
                      },
                      "salt": {
                        "description": "Salt for consistent hash bucketing across users. Auto-generated if omitted.",
                        "type": "string"
                      }
                    },
                    "required": [
                      "strategy",
                      "variants"
                    ]
                  },
                  {
                    "title": "Gradual Config",
                    "description": "Time-based progressive rollout - gradually increases traffic percentage at fixed intervals.",
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "description": "Time-based progressive rollout",
                        "type": "string",
                        "enum": [
                          "gradual"
                        ]
                      },
                      "variation_id": {
                        "format": "uuid",
                        "description": "Valid UUID v4 format",
                        "type": "string"
                      },
                      "target_percentage": {
                        "minimum": 0,
                        "maximum": 100,
                        "description": "Final target percentage after all increments (0-100)",
                        "type": "number"
                      },
                      "increment": {
                        "minimum": 0,
                        "maximum": 100,
                        "description": "Percentage increase per interval",
                        "type": "number"
                      },
                      "interval_hours": {
                        "minimum": 0,
                        "description": "Number of hours between each percentage increment",
                        "type": "number"
                      },
                      "salt": {
                        "description": "Salt for consistent hash bucketing. Auto-generated if omitted.",
                        "type": "string"
                      },
                      "start_at": {
                        "format": "date-time",
                        "type": "string",
                        "nullable": true,
                        "description": "ISO 8601 timestamp when rollout starts. If null or omitted, starts immediately."
                      }
                    },
                    "required": [
                      "strategy",
                      "variation_id",
                      "target_percentage",
                      "increment",
                      "interval_hours"
                    ]
                  }
                ]
              }
            }
          },
          "description": "Choose one strategy: \"off\" (disabled), \"percentage\" (progressive boolean), \"variant\" (A/B testing), or \"gradual\" (time-based progressive)."
        },
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
