                              "type": "string",
                              "enum": [
                                "exists"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "not_exists"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "startsWith"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "endsWith"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "contains"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "not_contains"
                              ]
                            }
                          ]
                        },
                        "value": {
                          "description": "Value(s) to compare against. Not required for exists/not_exists operators.",
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "number"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "number"
                              }
                            }
                          ]
                        },
                        "logical_op": {
                          "description": "Logical operator to combine with other conditions when multiple are present.",
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "AND"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "OR"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
