    "/billing/portal": {
      "get": {
        "tags": [
          "Billing"
        ],
        "description": "\n    Generate a **short-lived Stripe Billing Portal session** for an organization admin.  \n    This portal link allows the admin to manage billing-related tasks securely within Stripe's hosted UI.\n\n    ### What the portal provides\n    - View all current and past subscriptions tied to the organization\n    - Update payment methods (cards, bank accounts, etc.)\n    - View/download invoices and receipts\n    - Cancel or resume subscriptions\n    - Update billing information\n\n    The returned `url` is a temporary, single-use HTTPS link to Stripe's billing portal, e.g.:\n\n    ```text\n    https://billing.stripe.com/p/session/test_YWNjdF8xUjVENkJDdnlkaXZnY21CLF9UNzRYcVA3eDZ4eEExS0I2ZDNLUmhVUHVXWGZSd2xC01003ZjV6GWq\n    ```\n\n    ⚠️ **Security note:** This URL is short-lived and should only be shown to the authenticated admin requesting it. Do not persist or reuse it in your own database.\n  ",
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "query",
            "name": "orgId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "format": "uri",
                          "type": "string"
                        }
                      },
                      "required": [
                        "url"
                      ]
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
