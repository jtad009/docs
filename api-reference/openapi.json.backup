    "/projects/{projectId}/envs/{envId}/flags/{flagId}/targeting-rules": {
      "get": {
        "summary": "List targeting rules",
        "tags": [
          "Flag Targeting Rules"
        ],
        "description": "\nFetch all targeting rules for a specific flag in an environment.\nRules are returned ordered by order_index (ascending) then created_at.\n\n**Access:** Viewers, Editors, Admins for the project.\n\n**Use case:** Load all targeting rules to display in the Targeting UI.",
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "projectId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "envId",
            "required": true
          },
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "path",
            "name": "flagId",
            "required": true
          }
        ],
        "responses": {
