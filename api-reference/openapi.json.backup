      "post": {
        "summary": "Create Environment",
        "tags": [
          "Environments"
        ],
        "description": "Create a new environment under the given project. The environment name must be unique within the project. The slug is auto-generated from the name, and metadata can be included.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "slug": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "metadata": {
                    "description": "Flexible metadata for storing optional information about the environment.\n\nCommon use cases include:\n- region: e.g., \"eu-west-1\"\n- created_by: user ID of the creator\n- sdk_key: unique key for SDK initialization\n- color: UI color hex code (e.g., \"#4CAF50\")\n- is_protected: true to prevent accidental deletion or modification\n- notes: descriptive notes for admins\n- tags: custom array of strings (e.g., [\"internal\", \"qa\"])\n- default_locale: for language-based targeting\n- timezone: e.g., \"Europe/London\"",
                    "additionalProperties": true,
                    "type": "object",
                    "properties": {}
                  },
                  "is_active": {
                    "type": "boolean"
                  },
                  "is_default": {
                    "default": false,
