    "/billing/custom-inquiry": {
      "post": {
        "summary": "Submit a custom plan inquiry",
        "tags": [
          "Billing"
        ],
        "description": "Public endpoint — no auth required. Captures org context when the caller is authenticated. Rate limited to 3 submissions per IP per day.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "companyName": {
                    "minLength": 1,
                    "maxLength": 255,
                    "type": "string"
                  },
                  "website": {
                    "maxLength": 500,
                    "type": "string"
                  },
                  "contactEmail": {
                    "format": "email",
                    "maxLength": 255,
                    "type": "string"
                  },
                  "billingEmail": {
                    "format": "email",
                    "maxLength": 255,
                    "type": "string"
                  },
                  "estimatedTeamSize": {
                    "maxLength": 50,
                    "type": "string"
                  },
                  "estimatedApiCalls": {
                    "maxLength": 50,
                    "type": "string"
                  },
                  "projectCount": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "environmentCount": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "requiresSso": {
                    "type": "boolean"
                  },
                  "requiresAuditExport": {
                    "type": "boolean"
                  },
                  "requiresSla": {
                    "type": "boolean"
                  },
                  "requiresDedicatedSupport": {
                    "type": "boolean"
                  },
                  "billingPreference": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "monthly"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
                          "annual"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
                          "custom"
                        ]
                      }
                    ]
                  },
                  "migratingFrom": {
                    "maxLength": 255,
                    "type": "string"
                  },
                  "timeline": {
                    "maxLength": 100,
                    "type": "string"
                  },
                  "notes": {
                    "maxLength": 5000,
                    "type": "string"
                  }
                },
                "required": [
                  "companyName",
                  "contactEmail"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "statusCode",
                    "message"
                  ]
                }
              }
            }
          },
          "429": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "error": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string",
                      "default": "Too Many Requests"
                    }
                  },
                  "required": [
                    "message"
                  ]
                }
              }
            }
          },
          "500": {
