    "/projects/{projectId}/segments": {
      "post": {
        "summary": "Create a new segment",
        "tags": [
          "Segments"
        ],
        "description": "Creates a new audience segment with custom targeting rules. Segments are reusable groups of users defined by conditions (e.g., country='US' AND plan='premium') that can be referenced across multiple feature flags for consistent targeting. Each segment contains an array of conditions combined using a logical operator (AND or OR). With AND logic, all conditions must match for a user to be included. With OR logic, any single condition matching includes the user. Segments enable centralized audience management and reduce duplication across flag targeting rules.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "format": "uuid",
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "rules": {
                    "type": "array",
                    "items": {
                      "description": "A single segment rule used to evaluate if a user matches the segment.",
                      "type": "object",
                      "properties": {
                        "type": {
                          "description": "Type of rule. Always \"rule\". Reserved for future extensions like \"group\".",
                          "type": "string",
                          "enum": [
                            "rule"
                          ]
                        },
                        "attribute": {
                          "description": "The user or context attribute to match on.\n\nExamples:\n- \"country\"\n- \"email\"\n- \"plan\"",
                          "type": "string"
                        },
                        "operator": {
                          "description": "The operation used to evaluate the attribute.",
                          "anyOf": [
                            {
                              "description": "Equal to the specified value.",
                              "type": "string",
                              "enum": [
                                "eq"
                              ]
                            },
                            {
                              "description": "Not equal to the specified value.",
                              "type": "string",
                              "enum": [
                                "neq"
                              ]
                            },
                            {
                              "description": "Value is one of the specified values (array).",
                              "type": "string",
                              "enum": [
                                "in"
                              ]
                            },
                            {
                              "description": "Value is NOT one of the specified values (array).",
                              "type": "string",
                              "enum": [
                                "nin"
                              ]
                            },
                            {
                              "description": "Checks if the attribute exists and is not null/undefined.",
                              "type": "string",
                              "enum": [
                                "exists"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value starts with the specified value.",
                              "type": "string",
                              "enum": [
                                "startsWith"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value ends with the specified value.",
                              "type": "string",
                              "enum": [
                                "endsWith"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value contains the specified value.",
                              "type": "string",
                              "enum": [
                                "contains"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value does not contain the specified value.",
                              "type": "string",
                              "enum": [
                                "not_contains"
                              ]
                            },
                            {
                              "description": "Checks if the attribute does not exist or is null/undefined.",
                              "type": "string",
                              "enum": [
                                "not_exists"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value is greater than the specified value.",
                              "type": "string",
                              "enum": [
                                "gt"
                              ]
                            },
                            {
                              "description": "Checks if the attribute value is less than the specified value.",
                              "type": "string",
                              "enum": [
                                "lt"
                              ]
                            }
                          ]
                        },
                        "value": {
                          "description": "The value or values to compare against.\n\nRequired for all operators except \"exists\".",
                          "anyOf": [
                            {
                              "description": "A single string value (for eq/neq).",
                              "type": "string"
                            },
                            {
                              "description": "An array of string values (for in/nin).",
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            }
                          ]
                        }
                      },
                      "required": [
                        "type",
                        "attribute",
                        "operator",
                        "value"
                      ]
                    }
                  },
                  "logical_op": {
                    "description": "Logical operator to combine multiple rules. 'AND' requires all rules to match, 'OR' requires at least one rule to match.",
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "AND"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
                          "OR"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
                          "NOT"
                        ]
                      }
                    ]
                  },
                  "force": {
                    "default": false,
                    "type": "boolean"
                  },
                  "key": {
                    "description": "A unique key for the segment within the project.",
                    "pattern": "^[a-zA-Z0-9-_]+$",
                    "type": "string"
                  }
                },
                "required": [
                  "name",
                  "rules"
                ]
              }
            }
          },
          "required": true
        },
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "projectId",
            "required": true
          }
        ],
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
