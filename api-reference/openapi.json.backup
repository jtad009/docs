    "/auth/upload/{uploadId}/complete": {
      "post": {
        "summary": "Finalize TUS upload",
        "tags": [
          "Users",
          "Upload"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "uploadId",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
