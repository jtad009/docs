      "put": {
        "tags": [
          "Flag Variations"
        ],
        "description": "Update a variation's properties. Setting is_default=true will unset other defaults.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "updates": {
                    "minItems": 0,
                    "description": "Array of variations to create or update",
                    "type": "array",
                    "items": {
                      "description": "Variation input for create or update. If id is provided, updates existing; otherwise creates new.",
                      "type": "object",
                      "properties": {
                        "id": {
                          "format": "uuid",
                          "description": "If missing, creates new variation",
                          "type": "string"
                        },
                        "key": {
                          "minLength": 1,
                          "description": "Unique key for the variation within the flag",
                          "type": "string"
                        },
