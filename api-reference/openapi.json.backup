                          "format": "uuid",
                          "description": "Valid UUID v4 format",
                          "type": "string"
                        },
                        "flag_id": {
                          "format": "uuid",
                          "description": "Valid UUID v4 format",
                          "type": "string"
                        },
                        "environment_id": {
                          "format": "uuid",
                          "description": "Valid UUID v4 format",
                          "type": "string"
                        },
                        "strategy": {
                          "default": "off",
                          "anyOf": [
                            {
                              "description": "Disabled - always uses fallback value",
                              "type": "string",
                              "enum": [
                                "off"
                              ]
                            },
                            {
                              "description": "Progressive rollout for boolean flags",
                              "type": "string",
                              "enum": [
                                "percentage"
                              ]
                            },
                            {
                              "description": "Multivariate A/B testing with weighted variants",
                              "type": "string",
                              "enum": [
                                "variant"
                              ]
                            },
                            {
                              "description": "Time-based progressive rollout",
                              "type": "string",
                              "enum": [
                                "gradual"
                              ]
                            }
                          ]
                        },
                        "config": {
                          "title": "Rollout Configuration",
                          "description": "Choose one strategy: \"off\" (disabled), \"percentage\" (progressive boolean), \"variant\" (A/B testing), or \"gradual\" (time-based progressive).",
                          "anyOf": [
                            {
                              "title": "Off Config",
                              "description": "Always returns the fallback value. No variations are used.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "description": "Disables the rollout",
                                  "type": "string",
                                  "enum": [
                                    "off"
                                  ]
                                }
                              },
                              "required": [
                                "strategy"
                              ]
                            },
                            {
                              "title": "Percentage Config",
                              "description": "Progressive rollout - boolean flags that gradually enable for a percentage of users.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "description": "Progressive rollout - users are bucketed by percentage",
                                  "type": "string",
                                  "enum": [
                                    "percentage"
                                  ]
                                },
                                "variation_id": {
                                  "format": "uuid",
                                  "description": "Valid UUID v4 format",
                                  "type": "string"
                                },
                                "percentage": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Percentage of users to enable this variation for (0-100)",
                                  "type": "number"
                                },
                                "salt": {
                                  "description": "Salt for consistent hash bucketing across users. Auto-generated if omitted.",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "strategy",
                                "variation_id",
                                "percentage"
                              ]
                            },
                            {
                              "title": "Variant Config",
                              "description": "Multivariate A/B testing - distribute users across multiple variations with weighted traffic allocation.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "description": "Multivariate testing - distribute users across multiple variations",
                                  "type": "string",
                                  "enum": [
                                    "variant"
                                  ]
                                },
                                "variants": {
                                  "minItems": 1,
                                  "description": "List of variations with weights. Weights must sum to exactly 100%.",
                                  "type": "array",
                                  "items": {
                                    "description": "A variant with its traffic allocation weight",
                                    "type": "object",
                                    "properties": {
                                      "variation_id": {
                                        "format": "uuid",
                                        "description": "Valid UUID v4 format",
                                        "type": "string"
                                      },
                                      "weight": {
                                        "minimum": 0,
                                        "maximum": 100,
                                        "description": "Relative weight for this variant. All weights must sum to 100.",
                                        "type": "number"
                                      }
                                    },
                                    "required": [
                                      "variation_id",
                                      "weight"
                                    ]
                                  }
                                },
                                "salt": {
                                  "description": "Salt for consistent hash bucketing across users. Auto-generated if omitted.",
                                  "type": "string"
                                }
                              },
                              "required": [
                                "strategy",
                                "variants"
                              ]
                            },
                            {
                              "title": "Gradual Config",
                              "description": "Time-based progressive rollout - gradually increases traffic percentage at fixed intervals.",
                              "type": "object",
                              "properties": {
                                "strategy": {
                                  "description": "Time-based progressive rollout",
                                  "type": "string",
                                  "enum": [
                                    "gradual"
                                  ]
                                },
                                "variation_id": {
                                  "format": "uuid",
                                  "description": "Valid UUID v4 format",
                                  "type": "string"
                                },
                                "target_percentage": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Final target percentage after all increments (0-100)",
                                  "type": "number"
                                },
                                "increment": {
                                  "minimum": 0,
                                  "maximum": 100,
                                  "description": "Percentage increase per interval",
                                  "type": "number"
                                },
                                "interval_hours": {
                                  "minimum": 0,
                                  "description": "Number of hours between each percentage increment",
                                  "type": "number"
                                },
                                "salt": {
                                  "description": "Salt for consistent hash bucketing. Auto-generated if omitted.",
                                  "type": "string"
                                },
                                "start_at": {
                                  "format": "date-time",
                                  "type": "string",
                                  "nullable": true,
                                  "description": "ISO 8601 timestamp when rollout starts. If null or omitted, starts immediately."
                                }
                              },
                              "required": [
                                "strategy",
                                "variation_id",
                                "target_percentage",
                                "increment",
                                "interval_hours"
                              ]
                            }
                          ]
                        },
                        "created_at": {
                          "format": "date-time",
                          "type": "string"
                        },
                        "updated_at": {
                          "format": "date-time",
                          "type": "string"
                        },
