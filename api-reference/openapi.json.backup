      "post": {
        "summary": "Create targeting rule",
        "tags": [
          "Flag Targeting Rules"
        ],
        "description": "\nCreate a new targeting rule for a flag in an environment.\n\n**Access:** Org Admins or Editors only.\n\n**Rule types:**\n- `segment`: Matches users in a specific segment (requires segment_id)\n- `custom`: Matches users based on custom conditions (requires conditions array)\n\n**Important:**\n- For segment rules: provide segment_id, do not provide conditions\n- For custom rules: provide conditions array, do not provide segment_id\n- Conditions use AND semantics (all must match)\n- The serve field determines what value is returned when the rule matches",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "description": "Human-readable name for the rule",
                    "type": "string"
                  },
                  "kind": {
                    "description": "Type of rule: segment-based or custom conditions",
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "segment"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
                          "custom"
                        ]
                      }
                    ]
                  },
                  "conditions": {
                    "description": "Required when kind=\"custom\". Array of conditions (AND semantics)",
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "attribute": {
                          "description": "The attribute to evaluate (e.g., country, plan, email)",
                          "type": "string"
                        },
                        "operator": {
                          "description": "The operator to apply",
                          "default": "eq",
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "eq"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "neq"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "in"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "nin"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "gt"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "lt"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "exists"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "not_exists"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "startsWith"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "endsWith"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "contains"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "not_contains"
                              ]
                            }
                          ]
                        },
                        "value": {
                          "description": "Value(s) to compare against. Not required for exists/not_exists operators.",
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "number"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "number"
                              }
                            }
                          ]
                        },
                        "logical_op": {
                          "description": "Logical operator to combine with other conditions when multiple are present.",
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "AND"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "OR"
                              ]
                            },
                            {
                              "type": "string",
                              "enum": [
                                "NOT"
                              ]
                            }
                          ]
                        }
                      },
                      "required": [
                        "attribute",
                        "operator"
                      ]
                    }
                  },
                  "segment_id": {
                    "format": "uuid",
                    "type": "string",
                    "nullable": true
                  },
                  "variation_id": {
                    "format": "uuid",
                    "description": "ID of flag_variations row when this rule matches.",
                    "type": "string",
                    "nullable": true
                  },
                  "rollout_id": {
                    "format": "uuid",
                    "description": "ID of flag_rollouts row to use when this rule matches.",
                    "type": "string",
                    "nullable": true
                  },
                  "order_index": {
                    "description": "Order in which rules are evaluated (lower = higher priority). Defaults to 0",
                    "type": "number"
                  }
                },
                "required": [
