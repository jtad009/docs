    "/audit/logs": {
      "get": {
        "summary": "Get audit logs",
        "tags": [
          "Audit"
        ],
        "description": "Retrieve audit logs from Redis stream and/or database with filtering and pagination.",
        "parameters": [
          {
            "schema": {
              "minimum": 1,
              "type": "number"
            },
            "in": "query",
            "name": "page",
            "required": false,
            "description": "Page number for pagination (default: 1)"
          },
          {
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "type": "number"
            },
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "Number of items per page (default: 50, max: 100)"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "event_type",
            "required": false,
            "description": "Filter by event type (e.g., \"user.login_success\", \"flag.updated\")"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "actor_id",
            "required": false,
            "description": "Filter by the ID of the user who performed the action"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "org_id",
            "required": false,
            "description": "Filter by organization ID"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "project_id",
            "required": false,
            "description": "Filter by project ID"
          },
          {
            "schema": {
              "format": "date-time",
              "type": "string"
            },
            "in": "query",
            "name": "from_date",
            "required": false,
            "description": "Start date for filtering events (ISO 8601 format, e.g., \"2025-10-01T00:00:00Z\")"
          },
          {
            "schema": {
              "format": "date-time",
              "type": "string"
            },
            "in": "query",
            "name": "to_date",
            "required": false,
            "description": "End date for filtering events (ISO 8601 format, e.g., \"2025-10-31T23:59:59Z\")"
          },
          {
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "database"
                  ]
                },
                {
                  "type": "string",
                  "enum": [
                    "redis"
                  ]
                },
                {
                  "type": "string",
                  "enum": [
                    "both"
                  ]
                }
              ]
            },
            "in": "query",
            "name": "source",
            "required": false,
            "description": "Data source: \"redis\" for recent events, \"database\" for historical data, \"both\" for combined (default: \"both\")"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "sort",
            "required": false,
            "description": "Sort by field and direction in format \"field:direction\" (e.g., \"created_at:desc\", \"event_type:asc\"). Allowed fields: created_at, event_type, actor_id. Default: \"created_at:desc\""
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "number"
                    },
                    "message": {
                      "default": "OK",
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "stream_id": {
                                "type": "string"
                              },
                              "org_id": {
                                "type": "string"
                              },
                              "project_id": {
                                "type": "string"
                              },
                              "actor_id": {
                                "type": "string"
                              },
                              "actor": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "email": {
                                    "format": "email",
                                    "type": "string"
                                  },
                                  "name": {
                                    "type": "string"
                                  },
                                  "role": {
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "id",
                                  "email"
                                ]
                              },
                              "eventType": {
                                "type": "string"
                              },
                              "payload": {
                                "type": "object",
                                "additionalProperties": true
                              },
                              "created_at": {
                                "format": "date-time",
                                "type": "string"
                              },
                              "source": {
                                "anyOf": [
                                  {
                                    "type": "string",
                                    "enum": [
                                      "redis"
                                    ]
                                  },
                                  {
                                    "type": "string",
                                    "enum": [
                                      "database"
                                    ]
                                  }
                                ]
                              }
                            },
                            "required": [
                              "id",
                              "eventType",
                              "payload",
                              "created_at",
                              "source"
                            ]
                          }
                        },
                        "meta": {
                          "type": "object",
                          "properties": {
                            "total": {
                              "type": "number"
                            },
                            "page": {
                              "type": "number"
                            },
                            "pageCount": {
                              "type": "number"
                            }
                          },
                          "required": [
                            "total",
