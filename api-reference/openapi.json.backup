                                "description": "The operation used to evaluate the attribute.",
                                "anyOf": [
                                  {
                                    "description": "Equal to the specified value.",
                                    "type": "string",
                                    "enum": [
                                      "eq"
                                    ]
                                  },
                                  {
                                    "description": "Not equal to the specified value.",
                                    "type": "string",
