    "/projects/{projectId}/flags": {
      "post": {
        "tags": [
          "Flags"
        ],
        "description": "Create a new feature flag in a project. **Rate Limited:** Maximum 20 requests per organization per hour.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "key": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "type": {
                    "description": "Data type of the flag value",
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "boolean"
                        ]
                      },
                      {
                        "type": "string",
                        "enum": [
