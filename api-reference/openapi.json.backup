                                      "exists"
                                    ]
                                  },
                                  {
                                    "description": "Checks if the attribute value starts with the specified value.",
                                    "type": "string",
                                    "enum": [
                                      "startsWith"
                                    ]
                                  },
                                  {
                                    "description": "Checks if the attribute value ends with the specified value.",
                                    "type": "string",
                                    "enum": [
                                      "endsWith"
                                    ]
                                  },
                                  {
                                    "description": "Checks if the attribute value contains the specified value.",
                                    "type": "string",
                                    "enum": [
                                      "contains"
                                    ]
                                  },
                                  {
                                    "description": "Checks if the attribute value does not contain the specified value.",
                                    "type": "string",
                                    "enum": [
                                      "not_contains"
                                    ]
                                  },
                                  {
                                    "description": "Checks if the attribute does not exist or is null/undefined.",
                                    "type": "string",
                                    "enum": [
